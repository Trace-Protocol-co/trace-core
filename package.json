{
  "name": "trace-protocol",
  "version": "1.0.0",
  "type": "module",
  "description": "TRACE — The Authenticity Layer for the Internet",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "node --loader ts-node/esm --no-warnings middleware/server.ts",
